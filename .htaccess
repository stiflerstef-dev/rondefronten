Options -MultiViews
RewriteEngine On

# Schone URL voor over-ons
RewriteCond %{HTTP:X-Forwarded-Proto} =https [NC]
RewriteRule ^over-ons$ https://rondefronten.nl/over-ons.html [R=301,L]
RewriteRule ^over-ons$ /over-ons.html [R=301,L]

# /configurator legacy redirect → / (configurator IS de root)
RewriteCond %{HTTP:X-Forwarded-Proto} =https [NC]
RewriteRule ^configurator/?$ https://rondefronten.nl/ [R=301,L]
RewriteRule ^configurator/?$ / [R=301,L]

# SPA fallback voor non-existent paths → /index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [QSA,L]
