Options -MultiViews
RewriteEngine On

# Schema bewaren via X-Forwarded-Proto (nginx proxy)
RewriteCond %{HTTP:X-Forwarded-Proto} =https [NC]
RewriteRule ^over-ons$ https://rondefronten.nl/over-ons.html [R=301,L]

# Fallback zonder proxy-header
RewriteRule ^over-ons$ /over-ons.html [R=301,L]

# SPA fallback voor /configurator/* (serveer configurator/index.html)
RewriteCond %{REQUEST_URI} ^/configurator(/.*)?$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ /configurator/index.html [QSA,L]

# SPA fallback voor hoofdsite
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]
