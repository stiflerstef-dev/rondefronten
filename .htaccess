Options -MultiViews
RewriteEngine On

# Schone URLs voor losse pagina's
RewriteCond %{HTTP:X-Forwarded-Proto} =https [NC]
RewriteRule ^over-ons$ https://rondefronten.nl/over-ons.html [R=301,L]
RewriteRule ^over-ons$ /over-ons.html [R=301,L]

RewriteCond %{HTTP:X-Forwarded-Proto} =https [NC]
RewriteRule ^contact$ https://rondefronten.nl/contact.html [R=301,L]
RewriteRule ^contact$ /contact.html [R=301,L]

RewriteCond %{HTTP:X-Forwarded-Proto} =https [NC]
RewriteRule ^portfolio$ https://rondefronten.nl/portfolio.html [R=301,L]
RewriteRule ^portfolio$ /portfolio.html [R=301,L]

# /configurator zonder slash → /configurator/ (zodat assets-paden kloppen)
RewriteRule ^configurator$ /configurator/ [R=301,L]

# SPA fallback BINNEN /configurator/ (geen recursie naar root)
RewriteCond %{REQUEST_URI} ^/configurator/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^configurator/.* /configurator/index.html [L]

# SPA fallback voor de homepage-SPA op de root
RewriteCond %{REQUEST_URI} !^/configurator/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [QSA,L]
